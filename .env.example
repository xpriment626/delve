# Required for live source discovery.
EXA_API_KEY=

# Recommended primary model route through Coral's runtime LLM proxy.
CORAL_API_KEY=

# Optional fallback model route if the Coral LLM proxy is unavailable.
OPENROUTER_API_KEY=

# Optional local Coral server settings.
CORAL_SERVER_URL=http://localhost:5555
CORAL_SERVER_AUTH_KEY=dev
