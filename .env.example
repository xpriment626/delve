# Required for live source discovery.
EXA_API_KEY=

# Required for Coral Cloud LLM proxy access.
CORAL_API_KEY=

# Optional Coral LLM proxy model override. Defaults to deepseek-v4-pro.
DELVE_MODEL=deepseek-v4-pro

# Optional local Coral server settings.
CORAL_SERVER_URL=http://localhost:5555
CORAL_SERVER_AUTH_KEY=dev
