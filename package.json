{
  "name": "@itsshadowai/delve",
  "version": "0.1.0",
  "description": "Coral-backed multi-agent research CLI with a SQLite blackboard and Delve-style negotiation.",
  "license": "MIT",
  "author": "itsshadowai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xpriment626/delve.git"
  },
  "bugs": {
    "url": "https://github.com/xpriment626/delve/issues"
  },
  "homepage": "https://github.com/xpriment626/delve#readme",
  "keywords": [
    "agents",
    "coral",
    "research",
    "cli",
    "blackboard",
    "codex"
  ],
  "type": "module",
  "bin": {
    "delve": "dist/src/cli.js"
  },
  "files": [
    "dist/",
    "agent/",
    "agents/",
    "scripts/",
    "coral-config.toml",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "dev": "tsx src/cli.ts",
    "eve:dev": "eve dev",
    "coral:start": "node scripts/start-coral.mjs",
    "install-local": "npm run build && node scripts/install-local.mjs",
    "prepack": "npm run build",
    "prepublishOnly": "npm run check && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "ai": "^7.0.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "eve": "^0.17.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
