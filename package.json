{
  "name": "delve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "delve": "./dist/src/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test \"test/**/*.test.ts\"",
    "dev": "tsx src/cli.ts",
    "eve:dev": "eve dev",
    "coral:start": "node scripts/start-coral.mjs",
    "install-local": "npm run build && node scripts/install-local.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.21.0",
    "ai": "^7.0.0",
    "commander": "^14.0.2",
    "dotenv": "^17.2.3",
    "eve": "^0.17.1",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=24"
  }
}
